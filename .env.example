# Cal Agent — Required Environment Variables
# Copy to .env and fill in values before deploying

# ============================================================
# SUPABASE (GP3 project: ezlmmegowggujpcnzoda)
# ============================================================
SUPABASE_URL=https://ezlmmegowggujpcnzoda.supabase.co
SUPABASE_KEY=                        # service_role key (Supabase dashboard → Settings → API)

# Direct Postgres connection (optional — REST client is used if unset)
# postgresql://postgres.{project_ref}:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ============================================================
# AUTH
# ============================================================
SECRET_KEY=                          # Random string for JWT signing (openssl rand -hex 32)

# ============================================================
# AI
# ============================================================
ANTHROPIC_API_KEY=                   # Claude Sonnet — console.anthropic.com

# ============================================================
# EMAIL — REQUIRED for autonomous enforcement
# Without MAILGUN_API_KEY, cron jobs run but send nothing (silent failure)
# Mailgun setup: mailgun.com → Sending → Domains → add gp3.app
# ============================================================
MAILGUN_API_KEY=                     # Mailgun account → API Keys
MAILGUN_DOMAIN=gp3.app               # Sending domain registered in Mailgun

# ============================================================
# EMAIL SAFETY — Domain allowlist + dry-run
# Without these, emails default to gp3.app only + live sends
# ============================================================
EMAIL_ALLOWED_DOMAINS=buntingmagnetics.com,gp3.app   # Comma-separated allowed recipient domains
EMAIL_DRY_RUN=true                                     # true = log only, false = send via Mailgun

# ============================================================
# OPTIONAL
# ============================================================
ELEVENLABS_API_KEY=                  # TTS voice (not yet wired in frontend)
ENVIRONMENT=production
